rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user owns the resource by userId field
    function isOwnerByUserId() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // API Keys collection - users can read/write their own keys
    match /api-keys/{keyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // List API keys for the authenticated user
      allow list: if isAuthenticated();
    }
    
    // Billing collection - users can read their own billing data
    match /billing/{billingId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // List billing records for the authenticated user
      allow list: if isAuthenticated();
    }
    
    // Usage Logs collection - users can read their own usage logs
    match /usage-logs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // List usage logs for the authenticated user
      allow list: if isAuthenticated();
    }
    
    // Skills collection - users can read skills, only admin can write
    match /skills/{skillId} {
      allow read: if isAuthenticated();
      allow create: if false; // Only admin via backend
      allow update: if false; // Only admin via backend
      allow delete: if false; // Only admin via backend
      
      // List skills for authenticated users
      allow list: if isAuthenticated();
    }
    
    // Configuration collection (read-only for users)
    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write
    }
    
    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
