rules_version = '2';

// Velocity Brain — Firestore security rules
//
// Architecture (current):
// - Dashboard browser: Firebase Auth only (sign-in). No direct Firestore reads/writes in app code.
// - Node backend: Firebase Admin SDK for all data (bypasses these rules).
//
// Deploy after changes (from repo root or dashboard folder with firebase.json):
//   firebase deploy --only firestore:rules --project velocitybrainapp
//
// Backend collections (Admin SDK only — do not expose to clients):
//   users, workspaces, user_settings, api_keys, usage_logs, hosted_ingests,
//   agent_connections, agent_pairing_sessions, agent_tokens, agent_activity_runs,
//   agent_activity_steps, repo_registrations, insight_events,
//   source_connections, source_sync_jobs, source_artifacts, source_connection_events,
//   billing, skills

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profile doc (doc id = Firebase Auth uid)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Settings doc (doc id = Firebase Auth uid)
    match /user_settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Sensitive collections — backend API only (no client list leaks)
    match /workspaces/{workspaceId} {
      allow read, write: if false;
    }

    match /api_keys/{keyId} {
      allow read, write: if false;
    }

    match /usage_logs/{logId} {
      allow read, write: if false;
    }

    match /hosted_ingests/{docId} {
      allow read, write: if false;
    }

    match /agent_connections/{docId} {
      allow read, write: if false;
    }

    match /agent_pairing_sessions/{docId} {
      allow read, write: if false;
    }

    match /agent_tokens/{docId} {
      allow read, write: if false;
    }

    match /agent_activity_runs/{docId} {
      allow read, write: if false;
    }

    match /agent_activity_steps/{docId} {
      allow read, write: if false;
    }

    match /repo_registrations/{docId} {
      allow read, write: if false;
    }

    match /insight_events/{docId} {
      allow read, write: if false;
    }

    match /source_connections/{docId} {
      allow read, write: if false;
    }

    match /source_sync_jobs/{docId} {
      allow read, write: if false;
    }

    match /source_artifacts/{docId} {
      allow read, write: if false;
    }

    match /source_connection_events/{docId} {
      allow read, write: if false;
    }

    match /billing/{billingId} {
      allow read, write: if false;
    }

    match /skills/{skillId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Legacy / incorrect paths from older rules (explicit deny)
    match /api-keys/{document=**} {
      allow read, write: if false;
    }

    match /usage-logs/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
