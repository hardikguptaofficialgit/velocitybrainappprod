# Velocity Brain Dashboard — copy to `.env` for local development

# Backend API (must match backend PORT; or leave unset to use package.json proxy)
REACT_APP_API_URL=http://localhost:5004

# Company integrations UI (false = enabled; true = hide behind "coming soon")
REACT_APP_INTEGRATIONS_COMING_SOON=false

# Appwrite Cloud (client-side SDK — must match backend/.env)
REACT_APP_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
REACT_APP_APPWRITE_PROJECT_ID=replace-with-your-appwrite-project-id

REACT_APP_REVENUECAT_API_KEY=
