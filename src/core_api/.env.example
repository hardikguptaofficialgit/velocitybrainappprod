# VelocityBrain Core API Environment Configuration

# Application Settings
APP_NAME=Velocity Brain Core API
ENV=development
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://velocity:velocity@localhost:5432/velocitybrain
DB_CONNECT_TIMEOUT_SECONDS=5
DB_LOCK_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=15000

# Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Content Validation
MAX_CONTENT_LENGTH=10485760
MAX_QUERY_LENGTH=2000

# Logging
LOG_LEVEL=INFO
ENABLE_JSON_LOGGING=true
LOG_FILE=logs/core_api.log

# API Configuration
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=text-embedding-3-small
EMBED_DIM=1536
MODEL_ROUTER=native

# Paths
SKILLS_PATH=../skills
LOCAL_STORAGE_PATH=../data
WORKSPACE_ROOT=../
IDENTITY_SPEC_PATH=./identity.spec.json
