# Velocity Brain Core API - Local Development Example
# Copy to `.env` for local Python/API development.

# App
APP_NAME=Velocity Brain
ENV=dev
PORT=8080

# Database
DATABASE_URL=postgresql://velocity:velocity@localhost:5432/velocitybrain
DB_CONNECT_TIMEOUT_SECONDS=5
DB_LOCK_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=15000

# Core API auth
SECRET_KEY=replace-with-local-python-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# Embeddings / model routing
OPENAI_API_KEY=replace-with-openai-api-key
EMBED_DIM=1536
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=text-embedding-3-small
MODEL_ROUTER=native
EMBEDDING_SERVICE_URL=https://api.openai.com/v1/embeddings

# Reuse persistence
VELOCITYBRAIN_REUSE_BACKEND=database
VELOCITYBRAIN_REQUIRE_PERSISTENCE=0

# Runtime paths
SKILLS_PATH=skills
LOCAL_STORAGE_PATH=./data
WORKSPACE_ROOT=.
IDENTITY_SPEC_PATH=identity.spec.json

# Access / safety
DEFAULT_ACCESS_LEVEL=private
ALLOW_UNSAFE_FILE_READS=false
MCP_ALLOW_DESTRUCTIVE_TOOLS=false

# Optional integration to local Node backend
BACKEND_API_URL=http://localhost:5001

# Durable execution queue
JOB_QUEUE_BACKEND=database
JOB_QUEUE_REQUIRE_PERSISTENCE=0
JOB_TIMEOUT_SECONDS=300

# Logging
LOG_LEVEL=INFO
ENABLE_JSON_LOGGING=false
