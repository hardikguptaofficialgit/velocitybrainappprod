# Velocity Brain - Production Example
# Copy to `.env.prod` on the server and replace every placeholder.
# This file is used by `docker-compose.prod.yml`.

# App
APP_NAME=Velocity Brain
ENV=production
PORT=8080
# Keep false for the API-only droplet. The React dashboard runs on Vercel.
SERVE_DASHBOARD=false
# Host port used by the in-container VelocityBrain nginx. Keep this off 80/443
# when sharing the droplet with Linkit and route public HTTPS through Caddy.
NGINX_PORT=8088

# Database (Docker-internal host/port; not published on the droplet host)
DB_USER=velocity
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=velocitybrain
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
POSTGRES_USER=velocity
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=velocitybrain
DB_CONNECT_TIMEOUT_SECONDS=10
DB_LOCK_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000

# Redis (Docker-internal host/port; not published on the droplet host)
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Python API security
SECRET_KEY=replace-with-very-long-python-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# Node backend security
JWT_SECRET=replace-with-very-long-backend-jwt-secret
INTERNAL_USAGE_SECRET=replace-with-very-long-internal-usage-secret
ALLOW_PUBLIC_SIGNUP=true
APPROVED_USER_EMAILS=
APPROVED_USER_DOMAINS=

# Frontend origin for backend CORS
# Use your real Vercel/custom frontend URL here.
FRONTEND_URL=https://your-velocitybrain-dashboard.vercel.app
CORS_ORIGINS=https://your-velocitybrain-dashboard.vercel.app
CORS_ALLOW_CREDENTIALS=true

# OpenAI / embeddings
OPENAI_API_KEY=replace-with-openai-api-key
EMBED_DIM=1536
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_SERVICE_URL=https://api.openai.com/v1/embeddings
MODEL_ROUTER=native

# Reuse persistence
VELOCITYBRAIN_REUSE_BACKEND=database
VELOCITYBRAIN_REQUIRE_PERSISTENCE=1

# Runtime paths
SKILLS_PATH=skills
LOCAL_STORAGE_PATH=./data
WORKSPACE_ROOT=/app
IDENTITY_SPEC_PATH=identity.spec.json

# Access / safety
DEFAULT_ACCESS_LEVEL=private
ALLOW_UNSAFE_FILE_READS=false
MCP_ALLOW_DESTRUCTIVE_TOOLS=false

# Rate limiting / request validation
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
MAX_CONTENT_LENGTH=10485760
MAX_QUERY_LENGTH=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/velocitybrain.log
ENABLE_JSON_LOGGING=true

# Performance
WORKERS=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Health checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Backup / optional infrastructure
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
GRAFANA_PASSWORD=
PROMETHEUS_RETENTION=200h

# SSL paths if you terminate TLS in-container
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backend <-> API URLs inside the Docker network
BACKEND_API_URL=http://backend:5001
CORE_API_URL=http://api:8080

# Public URL for OAuth callbacks (must be HTTPS in production)
BACKEND_PUBLIC_URL=https://velocity.linkitapp.in

# VelAI onboarding (GitHub Models)
GITHUB_TOKEN=replace-with-github-models-pat
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Company integrations (leave empty for demo mode; set for live Slack/Google/GitHub OAuth)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INTEGRATION_TOKEN_SECRET=replace-with-integration-token-secret

# Durable execution queue
JOB_QUEUE_BACKEND=database
JOB_QUEUE_REQUIRE_PERSISTENCE=1
JOB_TIMEOUT_SECONDS=300

# Appwrite Cloud for backend auth, database, and storage
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69e7d0a0002573ec6840
APPWRITE_API_KEY=standard_replace_with_backend_api_key
APPWRITE_DATABASE_ID=velocitybrain
APPWRITE_PROFILE_IMAGES_BUCKET_ID=profile_images
APPWRITE_WORKSPACE_IMAGES_BUCKET_ID=workspace_images

# Dashboard/Vercel public values
# These are for the Vercel dashboard project. The API-only droplet compose file
# does not build or serve the React dashboard.
REACT_APP_API_URL=https://velocity.linkitapp.in
REACT_APP_INTEGRATIONS_COMING_SOON=true
REACT_APP_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
REACT_APP_APPWRITE_PROJECT_ID=69e7d0a0002573ec6840

# Billing / SaaS integrations
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REACT_APP_REVENUECAT_API_KEY=

# Debug
DEBUG=false
RELOAD=false
