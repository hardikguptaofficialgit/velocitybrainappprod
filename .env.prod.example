# Production Environment Configuration
# Copy this to .env.prod and update with your values

# Application Settings
APP_NAME=Velocity Brain
ENV=production
PORT=8080

# Database Settings (REQUIRED)
DB_USER=velocity
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
DB_NAME=velocitybrain
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Database Connection Settings
DB_CONNECT_TIMEOUT_SECONDS=10
DB_LOCK_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000

# Redis Settings (REQUIRED)
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Security Settings (REQUIRED)
SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Content Validation
MAX_CONTENT_LENGTH=10485760
MAX_QUERY_LENGTH=2000

# Embedding Settings
EMBED_DIM=1536
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=text-embedding-3-small
MODEL_ROUTER=native

# Path Settings
SKILLS_PATH=skills
LOCAL_STORAGE_PATH=./data
WORKSPACE_ROOT=/app
IDENTITY_SPEC_PATH=identity.spec.json

# Access Control
DEFAULT_ACCESS_LEVEL=private
ALLOW_UNSAFE_FILE_READS=false
MCP_ALLOW_DESTRUCTIVE_TOOLS=false

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=/app/logs/velocitybrain.log
ENABLE_JSON_LOGGING=true

# Monitoring
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=200h

# OpenAI Settings (if using OpenAI embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# External Service URLs (if applicable)
EMBEDDING_SERVICE_URL=https://api.openai.com/v1/embeddings

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# SSL/TLS Settings (for HTTPS)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# CORS Settings (if needed)
CORS_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Public frontend URL used by the Node backend
FRONTEND_URL=https://yourdomain.com

# Node backend auth/session settings
JWT_SECRET=CHANGE_THIS_BACKEND_JWT_SECRET
INTERNAL_USAGE_SECRET=CHANGE_THIS_BACKEND_INTERNAL_USAGE_SECRET

# Firebase Admin SDK for backend (REQUIRED for auth and dashboard data)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Dashboard build-time public Firebase configuration
REACT_APP_FIREBASE_API_KEY=replace-with-public-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Billing / SaaS integrations
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REACT_APP_REVENUECAT_API_KEY=replace-with-revenuecat-public-sdk-key

# Performance Settings
WORKERS=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Development/Debug Settings (DISABLE IN PRODUCTION)
DEBUG=false
RELOAD=false
