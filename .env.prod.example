# Velocity Brain - Production Example
# Copy to `.env.prod` on the server and replace every placeholder.
# This file is used by `docker-compose.prod.yml`.

# App
APP_NAME=Velocity Brain
ENV=production
PORT=8080

# Database (Docker internal defaults)
DB_USER=velocity
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=velocitybrain
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_CONNECT_TIMEOUT_SECONDS=10
DB_LOCK_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000

# Redis
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Python API security
SECRET_KEY=replace-with-very-long-python-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60

# Node backend security
JWT_SECRET=replace-with-very-long-backend-jwt-secret
INTERNAL_USAGE_SECRET=replace-with-very-long-internal-usage-secret

# Frontend origin for backend CORS
# Use your real Vercel/custom frontend URL here.
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://your-secondary-frontend-domain.com
CORS_ALLOW_CREDENTIALS=true

# OpenAI / embeddings
# Leave OPENAI_API_KEY blank if you are using the built-in local deterministic fallback.
OPENAI_API_KEY=
EMBED_DIM=1536
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=deterministic-local
MODEL_ROUTER=native

# Runtime paths
SKILLS_PATH=skills
LOCAL_STORAGE_PATH=./data
WORKSPACE_ROOT=/app
IDENTITY_SPEC_PATH=identity.spec.json

# Access / safety
DEFAULT_ACCESS_LEVEL=private
ALLOW_UNSAFE_FILE_READS=false
MCP_ALLOW_DESTRUCTIVE_TOOLS=false

# Rate limiting / request validation
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
MAX_CONTENT_LENGTH=10485760
MAX_QUERY_LENGTH=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/velocitybrain.log
ENABLE_JSON_LOGGING=true

# Performance
WORKERS=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Health checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Backup / optional infrastructure
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
GRAFANA_PASSWORD=
PROMETHEUS_RETENTION=200h

# SSL paths if you terminate TLS in-container
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backend <-> API URLs inside Docker network
BACKEND_API_URL=http://backend:5001
CORE_API_URL=http://api:8080

# Firebase Admin SDK for backend auth
# Prefer the downloaded service-account JSON file mounted/copied into the backend image.
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Dashboard/Vercel public Firebase values
REACT_APP_FIREBASE_API_KEY=replace-with-public-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Billing / SaaS integrations
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REACT_APP_REVENUECAT_API_KEY=

# Debug
DEBUG=false
RELOAD=false
