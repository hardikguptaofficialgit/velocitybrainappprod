# Velocity Brain Backend - Local/Server Example
# Copy to `backend/.env` for local Node backend runs.

# Server (use 5004 if 5001 is taken; keep dashboard proxy / REACT_APP_API_URL in sync)
PORT=5004
NODE_ENV=development

# Frontend URL allowed by CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend auth secrets (change for any shared/staging environment)
JWT_SECRET=replace-with-backend-jwt-secret
INTERNAL_USAGE_SECRET=replace-with-internal-usage-secret

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=velocitybrainapp
FIREBASE_PRIVATE_KEY_ID=replace-with-firebase-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=replace-with-firebase-service-account-email
FIREBASE_CLIENT_ID=replace-with-firebase-client-id
FIREBASE_DATABASE_URL=https://velocitybrainapp.firebaseio.com

# Public URL for OAuth callbacks (must match PORT)
BACKEND_PUBLIC_URL=http://localhost:5004

# Company integrations — leave empty for demo/simulated connections during local dev
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INTEGRATION_TOKEN_SECRET=replace-with-integration-token-secret

# VelAI onboarding (GitHub Models — OpenAI-compatible)
GITHUB_TOKEN=replace-with-github-models-token
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Core API integration
CORE_API_URL=http://localhost:8080
BACKEND_API_URL=http://localhost:5004
